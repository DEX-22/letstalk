{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": false,
    "types": ["vitest/globals"]
  },
  "include": [
    ".nuxt/nuxt.d.ts",
    "app/**/*.ts",
    "app/**/*.vue",
    "modules/**/*.ts",
    "modules/**/*.vue",
    "shared/**/*.ts",
    "shared/**/*.vue"
  ]
}